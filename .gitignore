# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/playwright/.cache

# perf artifacts — raw Lighthouse JSON dumps from scripts/lighthouse.mjs.
# The summary markdowns (lighthouse-{before,after}.md) are kept; the
# per-route JSON is large and reproducible on demand.
/docs/performance/lighthouse-before
/docs/performance/lighthouse-after

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.next
.cursor
# sentry
.sentryclirc
.env.sentry-build-plugin
